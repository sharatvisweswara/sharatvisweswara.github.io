---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	minutes?: number;
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, tags, minutes, headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="mx-auto max-w-3xl">
		<article class="mb-32 sm:mb-40">
			<header class="mb-12 sm:mb-16 max-w-2xl">
				<PostMeta
					pubDate={pubDate}
					updatedDate={updatedDate}
					minutes={minutes}
					tags={tags}
					class="mb-6"
				/>
				<h1 class="text-balance text-3xl sm:text-5xl font-bold tracking-tight leading-[1.1] text-slate-900 dark:text-slate-100">
					{title}
				</h1>
				{description && (
					<p class="mt-6 text-xl sm:text-2xl text-balance text-slate-600 dark:text-slate-300 leading-snug font-light">
						{description}
					</p>
				)}
				<div class="mt-10 h-px w-16 bg-primary-500/60"></div>
			</header>

			<TableOfContents headings={headings} />

			<div class="prose-editorial">
				<slot />
			</div>

			<footer class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
				<a
					href="/blog"
					class="inline-flex items-center gap-1 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
				>
					<span aria-hidden="true">←</span>
					<span>Back to all writing</span>
				</a>
			</footer>
		</article>
	</div>
</BaseLayout>
