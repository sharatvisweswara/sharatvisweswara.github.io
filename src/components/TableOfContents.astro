---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
	minHeadings?: number;
}

const { headings, minHeadings = 4 } = Astro.props;

const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const show = items.length >= minHeadings;
---

{show && (
	<nav aria-label="Table of contents" class="toc not-prose mb-10 sm:mb-12">
		<details class="group rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50/60 dark:bg-slate-900/40 open:bg-slate-50 dark:open:bg-slate-900/60 transition-colors" open>
			<summary class="cursor-pointer list-none flex items-center justify-between gap-3 px-4 py-3">
				<span class="eyebrow">Contents</span>
				<svg
					aria-hidden="true"
					class="h-4 w-4 text-slate-400 dark:text-slate-500 transition-transform group-open:rotate-180"
					viewBox="0 0 20 20"
					fill="currentColor"
				>
					<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
				</svg>
			</summary>
			<ol class="px-4 pb-4 pt-1 space-y-1.5 text-sm">
				{items.map((h) => (
					<li class={h.depth === 3 ? 'ml-4' : ''}>
						<a
							href={`#${h.slug}`}
							class="text-slate-600 dark:text-slate-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors leading-snug"
						>
							{h.text}
						</a>
					</li>
				))}
			</ol>
		</details>
	</nav>
)}

<style>
	.toc summary::-webkit-details-marker {
		display: none;
	}
</style>
