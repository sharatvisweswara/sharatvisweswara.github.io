---
import FormattedDate from './FormattedDate.astro';

interface Props {
	pubDate: Date;
	updatedDate?: Date;
	minutes?: number;
	tags?: string[];
	class?: string;
}

const { pubDate, updatedDate, minutes, tags, class: className = '' } = Astro.props;
---

<div class={`flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500 dark:text-slate-400 ${className}`}>
	<time class="font-mono tabular-nums" datetime={pubDate.toISOString()}>
		<FormattedDate date={pubDate} />
	</time>
	{minutes !== undefined && (
		<>
			<span aria-hidden="true" class="text-slate-300 dark:text-slate-700">·</span>
			<span class="font-mono tabular-nums">{minutes} min read</span>
		</>
	)}
	{updatedDate && (
		<>
			<span aria-hidden="true" class="text-slate-300 dark:text-slate-700">·</span>
			<span class="italic">updated <FormattedDate date={updatedDate} /></span>
		</>
	)}
	{tags && tags.length > 0 && (
		<ul class="flex flex-wrap gap-1.5 ml-0">
			{tags.map((tag) => (
				<li class="eyebrow rounded-full border border-slate-200 dark:border-slate-700 px-2 py-0.5">
					{tag}
				</li>
			))}
		</ul>
	)}
</div>
