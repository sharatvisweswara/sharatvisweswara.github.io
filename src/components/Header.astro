---
import { Icon } from 'astro-icon/components';
import LightDarkToggle from './LightDarkToggle.astro';
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', text: 'Home', active: currentPath === '/' },
	{ href: '/blog', text: 'Blog', active: currentPath.startsWith('/blog') },
	{ href: '/about', text: 'About', active: currentPath.startsWith('/about') },
];
---

<header>
	<div
		id="main-header"
		class="fixed inset-x-0 top-0 w-full z-50 transition duration-500 bg-white/95 backdrop-blur
		border-b border-slate-200 dark:bg-slate-900/95 dark:border-white/10 dark:text-slate-200"
	>
		<div class="w-full max-w-6xl mx-auto flex h-14 items-center justify-between px-4 sm:px-6 lg:px-8">
			<a href="/" class="font-headings font-black text-xl">{SITE_TITLE}</a>

			<div class="flex items-center h-full">
				<nav class="hidden md:block h-full">
					<ul class="flex space-x-6 h-full">
						{navItems.map((item) => (
							<li>
								<a
									href={item.href}
									class={`relative flex items-center h-full hover:text-primary-500 transition ${item.active ? 'text-primary-500' : ''}`}
								>
									{item.text}
									{item.active && (
										<span class="absolute inset-x-0 -bottom-px h-px bg-primary-500" />
									)}
								</a>
							</li>
						))}
					</ul>
				</nav>
				<div class="ml-4 flex items-center gap-1">
					<a
						href="https://github.com/sharatvisweswara"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub profile (opens in new tab)"
						class="inline-flex items-center justify-center w-8 h-8 transition hover:text-primary-500"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
							class="w-5 h-5"
						>
							<path d="M12 .5C5.73.5.66 5.57.66 11.84c0 5.01 3.24 9.26 7.74 10.76.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.11-3.15.69-3.81-1.34-3.81-1.34-.51-1.31-1.26-1.66-1.26-1.66-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.74 2.66 1.24 3.31.95.1-.74.4-1.24.72-1.53-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.16-3.05-.12-.29-.5-1.44.11-2.99 0 0 .95-.3 3.11 1.17a10.8 10.8 0 0 1 5.66 0c2.16-1.47 3.11-1.17 3.11-1.17.61 1.55.23 2.7.11 2.99.72.8 1.16 1.81 1.16 3.05 0 4.36-2.65 5.31-5.18 5.59.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .3.21.66.79.55 4.49-1.5 7.73-5.75 7.73-10.76C23.34 5.57 18.27.5 12 .5Z" />
						</svg>
					</a>
					<a
						href="https://www.linkedin.com/in/sharatvisweswara"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn profile (opens in new tab)"
						class="inline-flex items-center justify-center w-8 h-8 transition hover:text-primary-500"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
							class="w-5 h-5"
						>
							<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.59 0 4.26 2.36 4.26 5.43v6.31ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z" />
						</svg>
					</a>
					<button
						data-open-mobile-nav
						class="md:hidden inline-flex items-center justify-center w-10 h-10"
						aria-label="Open main navigation"
					>
						<Icon name="heroicons:bars-2-solid" class="inline-block w-5 h-5" />
					</button>
					<LightDarkToggle />
				</div>
			</div>
		</div>
	</div>

	<!-- Mobile nav backdrop -->
	<div
		data-mobile-nav-element
		data-close-mobile-nav
		class="hidden bg-black/50 fixed inset-0 z-60 backdrop-blur-xs transition opacity-0 starting:opacity-0"
	></div>

	<!-- Mobile nav panel -->
	<div
		data-mobile-nav-element
		class="hidden fixed z-60 inset-x-4 top-8 p-6 bg-white dark:bg-slate-800 dark:ring-white/10 dark:text-slate-200 shadow-md rounded-2xl transition starting:opacity-0 starting:scale-85 starting:-translate-y-8"
	>
		<div class="flex justify-end">
			<button data-close-mobile-nav aria-label="Close main navigation">
				<Icon name="heroicons:x-mark" />
			</button>
		</div>
		<nav>
			<ul class="divide-y divide-slate-200 dark:divide-slate-600">
				{navItems.map((item) => (
					<li>
						<a
							class={`block py-3 ${item.active ? 'text-primary-500' : ''}`}
							href={item.href}
						>
							{item.text}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
</header>
<script>
	function initNavigation() {
		const body = document.body;
		const scrollDown = 'scroll-down';
		let lastScroll = 0;
		const scrollThreshold = 50;

		window.addEventListener('scroll', () => {
			const currentScroll = window.scrollY;
			if (currentScroll <= 0) {
				body.classList.remove(scrollDown);
				return;
			}
			if (Math.abs(currentScroll - lastScroll) > scrollThreshold) {
				body.classList.toggle(scrollDown, currentScroll > lastScroll);
				lastScroll = currentScroll;
			}
		});

		const mobileNavElements = document.querySelectorAll('[data-mobile-nav-element]');

		document.querySelectorAll('[data-close-mobile-nav]').forEach((btn) => {
			btn.addEventListener('click', () => {
				mobileNavElements.forEach((el) => el.classList.add('hidden'));
			});
		});

		document.querySelectorAll('[data-open-mobile-nav]').forEach((btn) => {
			btn.addEventListener('click', () => {
				mobileNavElements.forEach((el) => {
					el.classList.remove('hidden');
					el.classList.add('opacity-100', 'block', 'scale-100', 'translate-y-0');
				});
			});
		});
	}

	initNavigation();
	document.addEventListener('astro:page-load', initNavigation);
</script>
