---
import { Icon } from 'astro-icon/components';
import PostMeta from './PostMeta.astro';
import { readingTime } from '../utils/readingTime';

interface Props {
	post: {
		id: string;
		body?: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			updatedDate?: Date;
			tags?: string[];
		};
	};
}

const { post } = Astro.props;
const minutes = readingTime(post.body);
---

<article class="group relative">
	<div
		class="absolute z-0 -inset-x-4 -inset-y-4 sm:rounded-lg opacity-0 scale-[0.98] group-hover:scale-100 group-hover:opacity-100 bg-slate-100/80 dark:bg-slate-800/60 transition duration-300"
	></div>
	<div class="relative py-4">
		<PostMeta
			pubDate={post.data.pubDate}
			updatedDate={post.data.updatedDate}
			minutes={minutes}
			tags={post.data.tags}
			class="mb-2"
		/>
		<h3 class="text-xl sm:text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
			<a href={`/blog/${post.id}`}>
				<span class="absolute inset-0"></span>
				<span>{post.data.title}</span>
			</a>
		</h3>
		<p class="mt-2 text-slate-600 dark:text-slate-300 leading-relaxed">{post.data.description}</p>
		<div class="flex items-center space-x-1 text-sm font-medium mt-3 text-slate-500 dark:text-slate-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
			<span>Read article</span>
			<Icon name="heroicons:arrow-right-16-solid" class="transition-transform group-hover:translate-x-0.5" />
		</div>
	</div>
</article>
