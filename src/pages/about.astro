---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Sharat Visweswara">
	<div class="mx-auto max-w-2xl">
		<header class="mb-12">
			<p class="eyebrow mb-4">About</p>
			<h1 class="text-4xl md:text-6xl font-black tracking-tight text-balance leading-[1.05] mb-6">Hi, I'm Sharat.</h1>
		</header>
		<div class="space-y-6 leading-8 text-slate-700 dark:text-slate-300 text-lg">
			<p>I started writing software when I was 10 and never stopped. I've worked on everything from kernel modules to massive distributed systems. I like building things that work well and look good.</p>
			<p>I currently work at <a href="https://evocalize.com" class="text-primary-600 dark:text-primary-400 font-medium hover:underline underline-offset-4">Evocalize</a> as a Founding Principal Engineer, previously at AWS and Amazon.</p>
		</div>
	</div>
</BaseLayout>
